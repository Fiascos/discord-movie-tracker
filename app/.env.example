# Discord Bot Token - отримайте з https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Google Sheets Spreadsheet ID (з URL таблиці)
SPREADSHEET_ID=your_spreadsheet_id_here

# Шлях до JSON файлу з обліковими даними Google Service Account
# Завантажте з https://console.cloud.google.com/apis/credentials
GOOGLE_CREDENTIALS_PATH=./credentials.json
